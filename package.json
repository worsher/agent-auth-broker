{
  "name": "agent-auth-broker",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@broker/web",
    "dev:mcp": "turbo run dev --filter=@broker/mcp-server",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@broker/web",
    "build:mcp": "turbo run build --filter=@broker/mcp-server",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "db:generate": "turbo run db:generate --filter=@broker/web",
    "db:push": "turbo run db:push --filter=@broker/web",
    "db:migrate": "turbo run db:migrate --filter=@broker/web"
  },
  "devDependencies": {
    "safe-regex2": "^5.1.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
