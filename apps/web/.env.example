# 数据库
DATABASE_URL="postgresql://postgres:password@localhost:5432/agent_auth_broker"

# NextAuth
NEXTAUTH_URL="http://localhost:3100"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# 凭证主加密密钥（64 位十六进制，即 32 bytes）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BROKER_MASTER_KEY="your-64-hex-chars-master-key"

# GitHub OAuth App（在 https://github.com/settings/developers 创建）
GITHUB_OAUTH_CLIENT_ID="your-github-client-id"
GITHUB_OAUTH_CLIENT_SECRET="your-github-client-secret"
